# Neon / PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require
REQUIRE_DATABASE=true
DATABASE_QUERY_TIMEOUT_MS=10000

# Optional aliases if you prefer different naming.
# NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# POSTGRES_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Optional: Neon PostgREST-compatible endpoint for future direct REST access.
# NEON_DATA_API_URL=https://PROJECT.apirest.REGION.aws.neon.tech/DBNAME/rest/v1

# Stripe
STRIPE_SECRET_KEY=sk_live_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Free plan does not require a Stripe price ID. It includes 1 mock interview trial in-product.
STRIPE_PRICE_STARTER=price_your_starter_price_id
STRIPE_PRICE_PROFESSIONAL=price_your_professional_price_id
STRIPE_PRICE_PREMIUM=price_your_premium_price_id

# Firebase Admin SDK
# Choose one option:
# 1. FIREBASE_SERVICE_ACCOUNT as a full JSON string
# 2. FIREBASE_SERVICE_ACCOUNT_PATH pointing to a local service-account JSON file
# 3. Individual fields below
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<your-private-key>\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Optional alternatives:
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# App / CORS
FRONTEND_URL=https://www.tryinterviews.site
PORT=3002

# Secure session cookies
SESSION_MAX_AGE_MS=432000000
SESSION_COOKIE_NAME=ti_session
FIREBASE_SESSION_COOKIE_NAME=__session
CSRF_COOKIE_NAME=ti_csrf
SESSION_COOKIE_PATH=/
# Set this if the backend and frontend should share a parent domain, for example `.tryinterviews.site`
# SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SAME_SITE=None

# Optional hardening knobs
RECENT_SIGN_IN_WINDOW_SECONDS=300

# OpenAI Interview Engine
# Keep the real API key in `.env.local`, never in tracked source control.
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_TIMEOUT_MS=45000
OPENAI_RETRY_ATTEMPTS=2
OPENAI_INTERVIEW_GENERATION_MODEL=gpt-5-mini
OPENAI_INTERVIEW_GENERATION_FALLBACK_MODEL=
OPENAI_INTERVIEW_EVALUATION_MODEL=gpt-5-mini
OPENAI_INTERVIEW_EVALUATION_FALLBACK_MODEL=
OPENAI_INTERVIEW_REASONING_EFFORT=low
INTERVIEW_ENGINE_QUESTION_COUNT=5
INTERVIEW_ENGINE_START_LIMIT=5
INTERVIEW_ENGINE_START_WINDOW_MS=600000
INTERVIEW_ENGINE_ANSWER_LIMIT=30
INTERVIEW_ENGINE_ANSWER_WINDOW_MS=600000
